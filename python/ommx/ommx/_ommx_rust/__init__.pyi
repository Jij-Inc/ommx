                    "used": int,
                    "fixed": int,
                    "dependent": int,
                    "irrelevant": int
                }
            },
            "constraints": {
                "total": int,
                "active": int,
                "removed": int
            }
        }
        ```

        # Examples
        --------

        ```python
        >>> from ommx.v1 import Instance
        >>> instance = Instance.empty()
        >>> stats = instance.stats()
        >>> stats["decision_variables"]["total"]
        0
        >>> stats["constraints"]["total"]
        0
        ```
        """
